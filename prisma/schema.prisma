generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// enums
enum Role {
  PATIENT
  COUNSELOR
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

enum AdminAction {
  BAN
  UNBAN
  SUSPEND
  UNSUSPEND
  VERIFY_COUNSELOR
  REVOKE_VERIFICATION
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_ADJUSTED
  APPOINTMENT_COMPLETED
  APPOINTMENT_REMINDER
  REVIEW_RECEIVED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  VERIFICATION_REVOKED
  ACCOUNT_BANNED
  ACCOUNT_UNBANNED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
}

// user model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phoneNumber   String?
  passwordHash  String
  role          Role      @default(PATIENT)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // soft ban/suspend fields — admin actions use these, never hard-delete
  isSuspended     Boolean   @default(false)
  suspendedUntil  DateTime?
  isBanned        Boolean   @default(false)
  suspendedAt     DateTime?
  bannedAt        DateTime?
  banReason       String?
  suspendReason   String?

  // relations
  patientProfile   PatientProfile?
  counselorProfile CounselorProfile?
  adminProfile     AdminProfile?

  adminActionsPerformed AdminActionLog[] @relation("AdminPerformer")
  adminActionsReceived  AdminActionLog[] @relation("AdminTarget")
  notifications         Notification[]
}

// profiles
model PatientProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  dateOfBirth DateTime?
  bio         String?  @db.Text
  isOnboarded Boolean  @default(false)
  
  appointments Appointment[]
  emotionLogs  EmotionLog[]
  reports      Report[]
}

model CounselorProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String
  professionalTitle String?            
  dateOfBirth       DateTime?
  experienceYears   Int
  hourlyRate        Decimal            @db.Decimal(10, 2)
  verificationStatus VerificationStatus @default(PENDING)
  bio               String?            @db.Text
  isOnboarded       Boolean            @default(false)
  
  specialties       CounselorSpecialty[]
  documents         VerificationDocument[]
  slots             AvailabilitySlot[]
  appointments      Appointment[]
  recurringSchedules RecurringSchedule[]
  reports            Report[]
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
}

// counselor specialties
model SpecialtyType {
  id    Int    @id @default(autoincrement())
  name  String @unique 
  
  counselors CounselorSpecialty[]
}

// bridge table
model CounselorSpecialty {
  id                 String           @id @default(cuid())
  counselorProfileId String
  specialtyId        Int
  
  counselor          CounselorProfile @relation(fields: [counselorProfileId], references: [id], onDelete: Cascade)
  specialty          SpecialtyType    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([counselorProfileId, specialtyId])
}

model VerificationDocument {
  id                 String           @id @default(cuid())
  counselorProfileId String
  documentUrl        String           
  uploadedAt         DateTime         @default(now())
  
  counselor          CounselorProfile @relation(fields: [counselorProfileId], references: [id], onDelete: Cascade)
}

// booking system
model AvailabilitySlot {
  id                 String           @id @default(cuid())
  counselorProfileId String
  startTime          DateTime
  endTime            DateTime
  isBooked           Boolean          @default(false)
  isBlocked          Boolean          @default(false)
  
  counselor          CounselorProfile @relation(fields: [counselorProfileId], references: [id], onDelete: Cascade)
  appointment        Appointment?
  
  @@index([startTime, endTime])
  @@index([counselorProfileId, startTime])
}

model RecurringSchedule {
  id                 String           @id @default(cuid())
  counselorProfileId String
  dayOfWeek          Int              // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime          String           // "HH:mm" format
  endTime            String           // "HH:mm" format
  
  counselor          CounselorProfile @relation(fields: [counselorProfileId], references: [id], onDelete: Cascade)
  
  @@unique([counselorProfileId, dayOfWeek, startTime])
  @@index([counselorProfileId])
}

model Appointment {
  id                 String            @id @default(cuid())
  slotId             String            @unique
  patientProfileId   String
  counselorProfileId String
  
  meetingLink          String?
  patientNote          String?           @db.Text
  medicalConcern       String?           @db.Text
  attachedEmotionLogId String?
  cancelledBy          Role?
  reminderSent         Boolean           @default(false)
  status               AppointmentStatus @default(SCHEDULED)
  createdAt            DateTime          @default(now())

  slot               AvailabilitySlot  @relation(fields: [slotId], references: [id])
  patient            PatientProfile    @relation(fields: [patientProfileId], references: [id])
  counselor          CounselorProfile  @relation(fields: [counselorProfileId], references: [id])
  attachedEmotionLog EmotionLog?       @relation(fields: [attachedEmotionLogId], references: [id], onDelete: SetNull)
  review             Review?
  reports            Report[]
  
  @@index([patientProfileId, status])
  @@index([counselorProfileId, status])
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  rating        Int
  comment       String?     @db.Text
  createdAt     DateTime    @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Report {
  id                 String      @id @default(cuid())
  appointmentId      String
  counselorProfileId String
  patientProfileId   String
  reason             String      @db.Text
  createdAt          DateTime    @default(now())

  appointment        Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  counselor          CounselorProfile @relation(fields: [counselorProfileId], references: [id], onDelete: Cascade)
  patient            PatientProfile   @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)

  @@index([counselorProfileId])
  @@index([patientProfileId])
}

// emotion logs
model EmotionLog {
  id               String         @id @default(cuid())
  patientProfileId String
  humeAnalysisJson Json
  dominantEmotion  String
  recordedAt       DateTime       @default(now())

  patient          PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  bookings         Appointment[]
}

// tracks every admin action for audit trail
model AdminActionLog {
  id           String      @id @default(cuid())
  adminUserId  String
  targetUserId String
  action       AdminAction
  reason       String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  admin        User @relation("AdminPerformer", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser   User @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([adminUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read])
}

// singleton row for platform-wide configuration — created on first read with defaults
model PlatformSettings {
  id              String   @id @default("singleton")
  suspendWarnAt   Int      @default(7)
  autoSuspendAt   Int      @default(10)
  autoSuspendDays Int      @default(5)
  banWarnAt       Int      @default(15)
  autoBanAt       Int      @default(20)
  updatedAt       DateTime @updatedAt
}